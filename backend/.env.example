# =============================================================================
# Catalog (events + clubs): prefers Supabase REST — set both (HTTPS, IPv4-safe).
# =============================================================================
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# If club_image stores a storage path (not a full URL), set the public bucket name:
# SUPABASE_CLUB_IMAGES_BUCKET=clubs

# Optional: raw Postgres for Nest (pg). Not required if catalog uses REST above.
# Direct db.*.supabase.co is often IPv6-only on home networks (ENOTFOUND on IPv4).
# Use Session pooler URI from Dashboard → Connect → Direct → Session pooler.
# DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# HS256 access tokens: JWT Secret from Dashboard → Settings → API (NOT anon / service_role keys).
# RS256/ES256 access tokens: leave unset; verification uses JWKS at SUPABASE_URL/auth/v1/.well-known/jwks.json
SUPABASE_JWT_SECRET=

# Supabase table for event bookmarks (columns: user_id, event_id; PK user_id+event_id). Default: bookmarks.
# SAVED_EVENTS_TABLE=bookmarks

# Optional: if tables are not named events / clubs / promotions
# CATALOG_EVENT_TABLE=events
# CATALOG_CLUB_TABLE=clubs
# CATALOG_PROMOTION_TABLE=promotions
# Optional: GET /api/suggestions DJ rows (Supabase table name)
# CATALOG_DJ_TABLE=djs

FRONTEND_ORIGIN=http://localhost:5173
PORT=3000

GOOGLE_CLIENT_ID=
GOOGLE_REDIRECT_URI=
APPLE_CLIENT_ID=
APPLE_REDIRECT_URI=

JWT_SECRET=change_me
