# =============================================================================
# Supabase project URL (auth/JWKS, optional public storage URLs for club images in catalog).
# Catalog reads use TypeORM + DATABASE_URL only — no service-role REST path.
# =============================================================================
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# If club_image stores a storage path (not a full URL), set the public bucket name:
# SUPABASE_CLUB_IMAGES_BUCKET=clubs

# TypeORM + pg use this. Use Supabase "Session pooler" on IPv4 networks (shared pooler is IPv4-proxied).
# Dashboard → Database → Connection string → Session pooler. Do not use direct db.<ref>.supabase.co locally.
# User is postgres.<project_ref> (note the dot). Host is like aws-1-eu-north-1.pooler.supabase.com — copy yours.
# DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-1-eu-north-1.pooler.supabase.com:5432/postgres

# HS256 access tokens: JWT Secret from Dashboard → Settings → API (NOT anon / service_role keys).
# RS256/ES256 access tokens: leave unset; verification uses JWKS at SUPABASE_URL/auth/v1/.well-known/jwks.json
SUPABASE_JWT_SECRET=

# Saved bookmarks use TypeORM entity `bookmarks` (table public.bookmarks). SAVED_EVENTS_TABLE is ignored by the Nest API; rename the table in generated-entities/Bookmarks if needed.

FRONTEND_ORIGIN=http://localhost:5173
PORT=3000

# Resend email delivery for staff invites. Use a verified domain for production.
RESEND_API_KEY=
RESEND_FROM=PartyOn <onboarding@resend.dev>

GOOGLE_CLIENT_ID=
GOOGLE_REDIRECT_URI=
APPLE_CLIENT_ID=
APPLE_REDIRECT_URI=
PORT=3000

JWT_SECRET=change_me

# Stripe (test mode) — Dashboard → Developers → API keys / Webhooks
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
