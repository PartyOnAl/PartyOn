# Supabase (Framework tab in Dashboard) — same project as Expo:
#   VITE_SUPABASE_URL = https://<project-ref>.supabase.co
#   VITE_SUPABASE_PUBLISHABLE_KEY = sb_publishable_...   (or legacy anon JWT in VITE_SUPABASE_ANON_KEY)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=
# Optional legacy anon key if you do not use publishable:
# VITE_SUPABASE_ANON_KEY=

# Nest API: leave unset in local dev to use Vite’s proxy (no CORS issues).
# Or set explicitly, e.g. VITE_API_URL=http://localhost:3000
# VITE_API_URL=
# If the API runs on another port, set both URL and proxy target:
# VITE_API_URL=http://localhost:4000
# VITE_API_PROXY_TARGET=http://localhost:4000
