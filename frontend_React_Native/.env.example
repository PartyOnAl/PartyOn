# Copy to .env and fill from Supabase → Project Settings → API
# Use the project URL and the anon (public) key — JWT keys usually start with eyJ...
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# NestJS backend URL — required for Stripe ticket payments
# Physical device / Expo Go: use your machine's LAN IP
#   EXPO_PUBLIC_API_URL=http://192.168.1.100:3000
# Android emulator:
#   EXPO_PUBLIC_API_URL=http://10.0.2.2:3000
# iOS simulator:
#   EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_API_URL=http://localhost:3000
